# Rust build artifacts
/target/

# Python-generated files (historical)
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Secrets
.env
.env.*
!.env.example

# Auto-generated version file
src/*/_version.py

# mkdocs build output
site/

# Familiar Data — per-user familiars now live in the platform data dir
# (~/.local/share/familiar-connect/familiars, override with FAMILIARS_ROOT;
# issue #201), so a `git clean -fdx` here can no longer wipe them. The only
# tracked entry under data/familiars/ is the _default profile skeleton; these
# rules keep it tracked while ignoring any legacy or opt-in in-repo familiars
# (e.g. FAMILIARS_ROOT pointed back here). Git won't descend into an ignored
# directory, so the rules match individual folders rather than the parent.
data/familiars/*
!data/familiars/_default/
/data/cache/*
# Local turn-detection ONNX models (Silero ~2 MB, Smart Turn v3 ~360 MB).
# Downloaded out of band; see docs/architecture/voice-pipeline.md.
/data/models/

.aider*

# Claude Code local agent artifacts (worktrees, run logs, locks)
.claude/projects/
.claude/worktrees/
.claude/scheduled_tasks.lock

# macOS Finder junk
.DS_Store