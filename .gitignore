# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Secrets
.env
.env.*
!.env.example

# Auto-generated version file
src/*/_version.py

# mkdocs build output
site/

# Familiar Data — every per-user familiar is ignored, but the
# checked-in default profile at data/familiars/_default/ is not.
# Git won't descend into an ignored directory, so the rules below
# match individual folders under data/familiars/ rather than the
# parent itself.
data/familiars/*
!data/familiars/_default/
/data/cache/*
# Local turn-detection ONNX models (Silero ~2 MB, Smart Turn v3 ~360 MB).
# Downloaded out of band; see docs/architecture/voice-pipeline.md.
/data/models/

.aider*