{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "discord-bot",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"lint": "prettier --check . && eslint --ext .js,.mjs,.cjs --format=pretty src",
		"format": "prettier --write . && eslint --ext .js,.mjs,.cjs --fix --format=pretty src",
		"discord": "node --require dotenv/config discord/index.js",
		"discord-deploy": "node --require dotenv/config discord/util/deploy.js"
	},
	"dependencies": {
		"@discordjs/core": "^1.1.0",
		"@discordjs/discord.js": "github:discordjs/discord.js",
		"@discordjs/opus": "^0.9.0",
		"@discordjs/voice": "^0.16.1",
		"@libsql/client": "^0.6.0",
		"amqplib": "^0.10.3",
		"discord.js": "^14.14.0",
		"dotenv": "^16.3.1",
		"file-saver": "^2.0.5",
		"libsodium-wrappers": "^0.7.13"
	},
	"devDependencies": {
		"@types/wav": "^1.0.4",
		"eslint": "^8.53.0",
		"eslint-config-neon": "^0.1.57",
		"eslint-formatter-pretty": "^5.0.0",
		"prettier": "^3.0.3"
	}
}
