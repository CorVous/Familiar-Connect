# Install-scoped secrets and env-only knobs. Per-character settings
# (LLM model + temperature, TTS voice/model, STT backend, turn-detection
# strategy) live in `data/familiars/<id>/character.toml`. Most env vars
# below override a matching TOML field — useful when character.toml is
# baked into a container but a few knobs need to differ per host.
# See `data/familiars/_default/character.toml` and
# `docs/architecture/tuning.md` for full context.

# ---------------------------------------------------------------------------
# Discord
# ---------------------------------------------------------------------------
DISCORD_BOT=

# ---------------------------------------------------------------------------
# OpenRouter (https://openrouter.ai/keys)
# ---------------------------------------------------------------------------
# Shared across every LLM call site; per-call-site model + temperature
# live in character.toml under [llm.main_prose].
OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# Cartesia TTS (https://play.cartesia.ai/keys)
# ---------------------------------------------------------------------------
# Required when [tts].provider="cartesia". Voice id and model are
# per-character: set them in character.toml under [tts].
CARTESIA_API_KEY=

# ---------------------------------------------------------------------------
# Azure Speech (https://portal.azure.com — Cognitive Services → Speech)
# ---------------------------------------------------------------------------
# Required when [tts].provider="azure" (the default). Voice name is
# per-character: set [tts].azure_voice in character.toml.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# ---------------------------------------------------------------------------
# Google Gemini TTS (https://aistudio.google.com/apikey)
# ---------------------------------------------------------------------------
# Required when [tts].provider="gemini". GEMINI_API_KEY is accepted as
# a fallback. Voice and model are per-character: set [tts].gemini_voice
# and [tts].gemini_model in character.toml. Optional style fields
# (gemini_audio_profile, gemini_scene, gemini_context, gemini_style,
# gemini_pace, gemini_accent) compose a performance prompt automatically.
GOOGLE_API_KEY=

# ---------------------------------------------------------------------------
# STT backend selector (V3)
# ---------------------------------------------------------------------------
# Picks the transcriber. Overrides [providers.stt].backend in
# character.toml. Defaults to "deepgram".
#   "deepgram"        — cloud, hosted endpointing
#   "parakeet"        — local NeMo (requires local-stt-parakeet extra)
#   "faster_whisper"  — local CTranslate2 (requires local-stt-whisper extra)
# Both local backends additionally require local turn detection
# (LOCAL_TURN_DETECTION=1 or [providers.turn_detection].strategy =
# "ten+smart_turn") since neither has an internal endpointer.
# STT_BACKEND=deepgram

# ---------------------------------------------------------------------------
# Deepgram (https://console.deepgram.com/) — cloud STT
# ---------------------------------------------------------------------------
# Required for STT_BACKEND=deepgram (the default). Without it
# /subscribe-my-voice joins and greets but never receives audio.
DEEPGRAM_API_KEY=
# Per-knob env overrides for [providers.stt.deepgram] (all optional;
# defaults shown match data/familiars/_default/character.toml):
# DEEPGRAM_MODEL=nova-3
# DEEPGRAM_LANGUAGE=en
# DEEPGRAM_ENDPOINTING_MS=500            # silence ms before a segment finalizes
# DEEPGRAM_UTTERANCE_END_MS=1500         # speech-end grace window
# DEEPGRAM_SMART_FORMAT=true             # punctuation, numbers, units
# DEEPGRAM_PUNCTUATE=true
# DEEPGRAM_KEYTERMS=                     # comma-separated; empty string clears
# DEEPGRAM_REPLAY_BUFFER_S=5.0           # seconds buffered for reconnect replay
# DEEPGRAM_KEEPALIVE_INTERVAL_S=3.0      # KeepAlive frame interval (~10s timeout)
# DEEPGRAM_RECONNECT_MAX_ATTEMPTS=5      # max consecutive failures before giving up
# DEEPGRAM_RECONNECT_BACKOFF_CAP_S=16.0  # ceiling for exponential backoff delay
# DEEPGRAM_IDLE_CLOSE_S=30.0             # close per-user stream after silence; 0 disables

# ---------------------------------------------------------------------------
# Parakeet local STT (V3 phase 2)
# ---------------------------------------------------------------------------
# Active when STT_BACKEND=parakeet (or [providers.stt].backend = "parakeet").
# Requires `uv sync --extra local-turn --extra local-stt-parakeet` and
# a local turn detector. Per-knob env overrides for
# [providers.stt.parakeet] (defaults shown):
# PARAKEET_MODEL_NAME=nvidia/parakeet-tdt-0.6b-v3
# PARAKEET_DEVICE=auto                   # "auto" | "cuda" | "cpu"
# PARAKEET_IDLE_CLOSE_S=30.0

# ---------------------------------------------------------------------------
# FasterWhisper local STT (V3 phase 3)
# ---------------------------------------------------------------------------
# Active when STT_BACKEND=faster_whisper. Requires `uv sync --extra
# local-turn --extra local-stt-whisper` and a local turn detector.
# Per-knob env overrides for [providers.stt.faster_whisper] (defaults shown):
# FASTER_WHISPER_MODEL_SIZE=small        # "tiny" | "base" | "small" | "medium" | "large-v3"
# FASTER_WHISPER_DEVICE=auto             # "auto" | "cuda" | "cpu"
# FASTER_WHISPER_COMPUTE_TYPE=auto       # "auto" | "int8" | "float16" | "float32"
# FASTER_WHISPER_LANGUAGE=en
# FASTER_WHISPER_IDLE_CLOSE_S=30.0

# ---------------------------------------------------------------------------
# Local turn detection (V1)
# ---------------------------------------------------------------------------
# Activates the TEN-VAD + Smart Turn v3 endpointer chain — saves
# 150–200 ms vs. Deepgram's hosted endpointer, and is required when
# STT_BACKEND is parakeet/faster_whisper. Requires `uv sync --extra
# local-turn` and a Smart Turn ONNX file.
#
# Setting LOCAL_TURN_DETECTION=1 overrides [providers.turn_detection]
# .strategy at startup (mirrors the STT_BACKEND precedent).
# LOCAL_TURN_DETECTION=1
# SMART_TURN_MODEL_PATH=data/models/smart-turn-v3.onnx
# Tuning knobs (defaults shown):
# LOCAL_TURN_SILENCE_MS=200              # silence after speech before classifier runs
# LOCAL_TURN_SPEECH_START_MS=100         # min speech before VAD reports start
# LOCAL_TURN_VAD_THRESHOLD=0.5           # TEN-VAD activation threshold
# LOCAL_TURN_SMART_TURN_THRESHOLD=0.5    # Smart Turn completion-probability cut
# TEN_VAD_HOP_SIZE=256                   # samples per VAD frame; 16 ms at 16 kHz

# ---------------------------------------------------------------------------
# Familiar selection
# ---------------------------------------------------------------------------
# Which character under data/familiars/<id>/ to run. Override per
# invocation with `familiar-connect run --familiar <id>`.
FAMILIAR_ID=
