# Discord
DISCORD_BOT=

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o
OPENROUTER_TEMPERATURE=0.7

# Cartesia TTS (https://play.cartesia.ai/keys)
# Required for voice output; without it the bot speaks text only.
CARTESIA_API_KEY=
# Optional: override the default voice. Browse voices at https://play.cartesia.ai
CARTESIA_VOICE_ID=
# Optional: override the model (default: sonic-3)
CARTESIA_MODEL=

# Character card and preset (text-chat prototype)
# Path to a SillyTavern Character Card V3 PNG file
FAMILIAR_CHARACTER=
# Path to a SillyTavern preset JSON file
FAMILIAR_PRESET=
