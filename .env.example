# Install-scoped secrets. Everything else lives in the active
# familiar's `data/familiars/<id>/character.toml` — LLM model choice,
# temperature per call site, and TTS voice/model are all per-character
# concerns now. See data/familiars/_default/character.toml for the
# reference profile.

# Discord
DISCORD_BOT=

# OpenRouter (https://openrouter.ai/keys)
# The API key is shared across every LLM call site; per-call-site
# model choice and temperature live in character.toml under
# [llm.main_prose], [llm.post_process_style], [llm.reasoning_context],
# [llm.history_summary], [llm.memory_search], and
# [llm.interjection_decision].
OPENROUTER_API_KEY=

# Cartesia TTS (https://play.cartesia.ai/keys)
# Required when TTS_PROVIDER=cartesia (or [tts].provider="cartesia").
# Voice id and model are per-character: set them in
# character.toml under [tts].
CARTESIA_API_KEY=

# Azure Speech (https://portal.azure.com — Cognitive Services → Speech)
# Required when TTS_PROVIDER=azure (or [tts].provider="azure", the default).
# Voice name is per-character: set [tts].azure_voice in character.toml.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Google Gemini TTS (https://aistudio.google.com/apikey)
# Required when [tts].provider="gemini".
# Voice and model are per-character: set [tts].gemini_voice and
# [tts].gemini_model in character.toml. Optional style fields
# (gemini_audio_profile, gemini_scene, gemini_context, gemini_style,
# gemini_pace, gemini_accent) compose a performance prompt automatically.
GOOGLE_API_KEY=

# Deepgram (https://console.deepgram.com/) — voice transcription.
# Required for any voice-channel listening (DEEPGRAM_API_KEY). Without
# it /subscribe-my-voice joins and greets but never receives audio.
# Model and language optional; defaults are nova-3 / en.
DEEPGRAM_API_KEY=
# DEEPGRAM_MODEL=nova-3
# DEEPGRAM_LANGUAGE=en
# Reconnect resilience (all optional — defaults shown):
# DEEPGRAM_REPLAY_BUFFER_S=5.0          # seconds of audio buffered for replay on reconnect
# DEEPGRAM_KEEPALIVE_INTERVAL_S=3.0     # KeepAlive frame interval (prevents ~10s idle timeout)
# DEEPGRAM_RECONNECT_MAX_ATTEMPTS=5     # max consecutive failures before giving up
# DEEPGRAM_RECONNECT_BACKOFF_CAP_S=16.0 # ceiling for exponential backoff delay


# Select which character under data/familiars/<id>/ to run.
# Override per-invocation with `familiar-connect run --familiar <id>`.
FAMILIAR_ID=
