# Discord
DISCORD_BOT=

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o
OPENROUTER_TEMPERATURE=0.7

# Optional: cheaper model used for side-model work (stepped thinking,
# recast, history summary, content search). When unset, those calls
# reuse the main OPENROUTER_MODEL — which works but can be expensive
# and slow, because the content-search agent in particular runs up to
# 5 side-model calls per turn. Recommended starting points:
#   openai/gpt-4o-mini
#   anthropic/claude-3.5-haiku
#   meta-llama/llama-3.1-8b-instruct
# OPENROUTER_SIDE_MODEL=openai/gpt-4o-mini
# OPENROUTER_SIDE_TEMPERATURE=0.5

# Cartesia TTS (https://play.cartesia.ai/keys)
# Required for voice output; without it the bot speaks text only.
CARTESIA_API_KEY=
# Optional: override the default voice. Browse voices at https://play.cartesia.ai
CARTESIA_VOICE_ID=
# Optional: override the model (default: sonic-3)
CARTESIA_MODEL=

# Select which character under data/familiars/<id>/ to run.
# Override per-invocation with `familiar-connect run --familiar <id>`.
FAMILIAR_ID=
