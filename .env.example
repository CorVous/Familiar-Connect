# Install-scoped secrets and deployment identity. Everything else —
# LLM model + temperature, TTS voice/model, STT backend selection,
# turn-detection strategy + tuning, per-knob defaults — lives in
# `data/familiars/<id>/character.toml`. See
# `data/familiars/_default/character.toml` for the reference profile.

# Discord bot token.
DISCORD_BOT=

# OpenRouter (https://openrouter.ai/keys). Shared across every LLM call
# site; per-call-site model + temperature live in [llm.<slot>].
OPENROUTER_API_KEY=

# Cartesia TTS (https://play.cartesia.ai/keys). Required when
# [tts].provider="cartesia".
CARTESIA_API_KEY=

# Azure Speech (https://portal.azure.com — Cognitive Services → Speech).
# Required when [tts].provider="azure" (the default).
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Google Gemini (https://aistudio.google.com/apikey). Required when
# [tts].provider="gemini". `GEMINI_API_KEY` is accepted as a fallback.
GOOGLE_API_KEY=

# Deepgram (https://console.deepgram.com/) — required when
# [providers.stt].backend="deepgram" (the default). All other Deepgram
# knobs (model, language, endpointing, keyterms, …) live in
# [providers.stt.deepgram].
DEEPGRAM_API_KEY=

# Which character under data/familiars/<id>/ to run. Override per
# invocation with `familiar-connect run --familiar <id>`.
FAMILIAR_ID=
